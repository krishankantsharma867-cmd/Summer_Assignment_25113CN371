#include <stdio.h>

int main() {
    int arr[100],n,item,pos;

    printf("Enter number of elements: ");
    scanf("%d",&n);

    printf("Enter array elements:");
    for(int i=0;i<n;i++) {
        scanf("%d", &arr[i]);
    }

    printf("Enter element to search: ");
    scanf("%d",&item);

    for(int i=0; i<n;i++) {
        if(arr[i]==item){
           pos=i;
        }
    }
    if(pos!=-1)
        printf("Element found at position %d", pos + 1);
    else
        printf("Element not found");

    return 0;
}

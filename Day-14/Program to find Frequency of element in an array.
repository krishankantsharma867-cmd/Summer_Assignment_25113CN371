#include <stdio.h>

int main() {
    int n,arr[100],item,count=0;

    printf("Enter number of elements: ");
    scanf("%d",&n);

    printf("Enter array elements:\n");
    for(int i=0;i<n;i++) {
        scanf("%d",&arr[i]);
    }

    printf("Enter element to find frequency: ");
    scanf("%d",&item);

    for(int i=0;i<n;i++) {
        if(arr[i]==item) {
            count++;
        }
    }

    printf("Frequency of %d = %d",item,count);
    return 0;
}
